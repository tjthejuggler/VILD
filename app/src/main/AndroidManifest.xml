<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Hold Tail's signature permission so we can receive its
        ACTION_HABIT_INCREMENTED broadcast (auto day-mode switch feature).
    -->
    <uses-permission android:name="com.example.tail.permission.TAIL_INTEGRATION" />

    <!-- Notification permission (required on Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required to reschedule alarms after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Required for exact alarm scheduling on Android 12+ -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VILD">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.VILD">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            BroadcastReceiver: listens for Tail's ACTION_HABIT_INCREMENTED broadcast.
            When the "auto switch to day mode" setting is enabled and VILD is currently
            in night mode, this receiver switches to day mode and pushes settings to
            the watch — even if VILD's UI is not open.
            Protected by Tail's signature permission so only same-keystore apps can
            trigger it.
        -->
        <receiver
            android:name=".ipc.DayModeSwitchReceiver"
            android:exported="true"
            android:permission="com.example.tail.permission.TAIL_INTEGRATION">
            <intent-filter>
                <action android:name="com.example.tail.ACTION_HABIT_INCREMENTED" />
            </intent-filter>
        </receiver>

        <!--
            BroadcastReceiver: fires the daily reality check notification at 8 AM.
            Also handles BOOT_COMPLETED to reschedule the alarm after reboot.
        -->
        <receiver
            android:name=".ipc.DailyTriggerReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.vild.ACTION_DAILY_TRIGGER" />
            </intent-filter>
        </receiver>

        <!--
            BroadcastReceiver: reschedules the daily trigger alarm after device reboot.
        -->
        <receiver
            android:name=".ipc.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>